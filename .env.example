# Environment Variables Template
# คัดลอกไฟล์นี้เป็น .env แล้วใส่ค่าจริง (อย่า commit .env ขึ้น GitHub!)

# Google Gemini API Key — รับได้ที่ https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Discord Webhook URL — สร้างได้ที่ Server Settings > Integrations > Webhooks
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/your_webhook_here
